<Window x:Class="KnowledgeLauncher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="计算机知识库启动器"
        Width="680" Height="500" MinWidth="600" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        Loaded="Window_Loaded">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="计算机知识库" FontSize="28" FontWeight="SemiBold" Foreground="#17202A" />
            <TextBlock Margin="0,6,0,0" Text="首次安装、配置插件并通过 Obsidian 打开知识库" Foreground="#566573" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,22,0,14" Padding="16" Background="White" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="知识库" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Margin="22,0,0,0" Text="danlingdan/ComputerKnowledgeBase" />
                <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Obsidian" FontWeight="SemiBold" />
                <TextBlock x:Name="ObsidianStatusText" Grid.Row="1" Grid.Column="1" Margin="22,8,0,0" Text="正在检查…" />
                <TextBlock Grid.Row="2" Margin="0,8,0,0" Text="安装状态" FontWeight="SemiBold" />
                <TextBlock x:Name="VaultStatusText" Grid.Row="2" Grid.Column="1" Margin="22,8,0,0" Text="正在检查…" />
                <TextBlock Grid.Row="3" Margin="0,8,0,0" Text="上次成功" FontWeight="SemiBold" />
                <TextBlock x:Name="LastSuccessText" Grid.Row="3" Grid.Column="1" Margin="22,8,0,0" Text="—" />
            </Grid>
        </Border>

        <ProgressBar x:Name="OperationProgress" Grid.Row="2" Height="5" Margin="0,0,0,14"
                     IsIndeterminate="True" Visibility="Collapsed" />

        <Border Grid.Row="3" Padding="16" Background="White" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="操作记录" FontWeight="SemiBold" />
                <TextBox x:Name="StatusTextBox" Grid.Row="1" Margin="0,12,0,0"
                         Text="准备就绪。" IsReadOnly="True" BorderThickness="0"
                         Background="Transparent" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <WrapPanel Grid.Row="4" Margin="0,18,0,0" HorizontalAlignment="Right">
            <Button x:Name="InstallObsidianButton" Width="120" Height="36" Margin="0,0,8,8"
                    Content="安装 Obsidian" Click="InstallObsidianButton_Click" />
            <Button x:Name="CancelButton" Width="80" Height="36" Margin="0,0,8,8"
                    Content="取消" IsEnabled="False" Click="CancelButton_Click" />
            <Button x:Name="InstallButton" Width="110" Height="36" Margin="0,0,8,8"
                    Content="安装知识库" Click="InstallButton_Click" />
            <Button x:Name="UpdateButton" Width="100" Height="36" Margin="0,0,8,8"
                    Content="检查更新" IsEnabled="False" Click="UpdateButton_Click" />
            <Button x:Name="RepairButton" Width="100" Height="36" Margin="0,0,8,8"
                    Content="修复安装" IsEnabled="False" Click="RepairButton_Click" />
            <Button x:Name="LogsButton" Width="100" Height="36" Margin="0,0,8,8"
                    Content="打开日志" Click="LogsButton_Click" />
            <Button x:Name="OpenButton" Width="110" Height="36" Margin="0,0,0,8"
                    Content="打开知识库" IsEnabled="False" Click="OpenButton_Click" />
        </WrapPanel>
    </Grid>
</Window>
